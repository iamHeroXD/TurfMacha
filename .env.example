# ══════════════════════════════════════════════════════════════
# TurfMacha — Complete Environment Variables
# Copy this file to .env.local and fill in your values.
# All NEXT_PUBLIC_* keys are safe to expose in the browser.
# All others are server-side ONLY.
# ══════════════════════════════════════════════════════════════

# ── Supabase (REQUIRED) ────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App URL (REQUIRED) ────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://turfmacha.vercel.app

# ── Razorpay — India Payments (REQUIRED for payments) ──────────
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
# Set in Razorpay Dashboard → Webhooks → Secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# ── Upstash Redis — Rate Limiting (RECOMMENDED for production) ─
# Get at upstash.com → Create Redis database
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Firebase — Push Notifications (OPTIONAL) ───────────────────
# Create project at console.firebase.google.com
# Add Web app → Project Settings → Your apps → SDK setup
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Cloud Messaging → Web configuration → Key pair (VAPID key)
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# ── MSG91 — WhatsApp & SMS India (OPTIONAL) ────────────────────
# Create account at msg91.com → Get auth key
MSG91_AUTH_KEY=
MSG91_WHATSAPP_SENDER_ID=
MSG91_SMS_SENDER_ID=TRFMCH
# DLT registered template IDs (mandatory for Indian SMS)
MSG91_SMS_TEMPLATE_ID=
MSG91_SMS_CANCEL_TEMPLATE_ID=

# ── PostHog — Product Analytics (OPTIONAL) ─────────────────────
# Create project at posthog.com
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Sentry — Error Monitoring (OPTIONAL) ───────────────────────
# npm install @sentry/nextjs  then set DSN
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@o0.ingest.sentry.io/xxxx
